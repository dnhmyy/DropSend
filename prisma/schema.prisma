// prisma-client-js configuration
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model File {
  id        String    @id
  filename  String
  path      String
  size      Int
  mimeType  String?
  expiresAt DateTime?
  downloads Int       @default(0)
  createdAt DateTime  @default(now())
}
